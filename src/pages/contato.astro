---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Contato — Viabilix"
  description="Fale com a Viabilix sobre regularização, licenciamento e gestão de documentação para sua empresa."
  active="contato"
>
<section class="page-header">
  <div class="wrap">
    <span class="eyebrow">Contato</span>
    <h1>Vamos organizar o que sua empresa precisa regularizar.</h1>
    <p>Conta a situação atual — retornamos com o diagnóstico e os próximos passos.</p>
  </div>
  <svg class="page-header-mark" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
    <polyline points="70,40 330,200 70,360" stroke="#C8CDD2" stroke-width="16" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <polyline points="70,120 270,200 70,280" stroke="#601830" stroke-width="16" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</section>

<section class="contato-section">
  <div class="wrap">
    <div class="contato-grid">

      <div class="contact-info-card">
        <h3>Fale diretamente</h3>
        <div class="contact-line">
          <div>
            <strong>E-mail</strong>
            <p>contato@viabilix.com.br</p>
          </div>
        </div>
        <div class="contact-line">
          <div>
            <strong>Central de atendimento</strong>
            <p>0800 000 0000 (em breve)</p>
          </div>
        </div>
        <div class="contact-line">
          <div>
            <strong>Atuação</strong>
            <p>Todo o Brasil</p>
          </div>
        </div>
        <div class="contact-line">
          <div>
            <strong>Atendimento</strong>
            <p>Segunda a sexta, 9h às 18h</p>
          </div>
        </div>
        <div class="socials">
          <a href="#" aria-label="Instagram"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/></svg></a>
          <a href="#" aria-label="LinkedIn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="8" y1="11" x2="8" y2="16"/><line x1="8" y1="8" x2="8" y2="8"/><line x1="12" y1="11" x2="12" y2="16"/><path d="M12 13c0-1.5 1-2 2-2s2 .5 2 2v3"/></svg></a>
          <a href="#" aria-label="WhatsApp"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 21l1.5-4.5A8 8 0 1 1 8.5 19.5L3 21z"/><path d="M8.5 9.5c0 3.5 3 6.5 6.5 6.5.5-1 1-2 .5-2.5-.5-.5-1.5-1-2-.5s-1 .5-1.5 0-1.5-1.5-2-2-.5-1.5 0-2-.5-1.5-1-2-2 .5-2.5.5z"/></svg></a>
        </div>
      </div>

      <div class="form-card">
        <form action="mailto:contato@viabilix.com.br" method="post" enctype="text/plain">
          <div class="form-row">
            <div class="form-group">
              <label for="nome">Nome</label>
              <input type="text" id="nome" name="nome" required>
            </div>
            <div class="form-group">
              <label for="empresa">Empresa</label>
              <input type="text" id="empresa" name="empresa">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">E-mail</label>
              <input type="email" id="email" name="email" required>
            </div>
            <div class="form-group">
              <label for="telefone">Telefone / WhatsApp</label>
              <input type="tel" id="telefone" name="telefone">
            </div>
          </div>
          <div class="form-group">
            <label for="servico">Serviço de interesse</label>
            <select id="servico" name="servico">
              <option value="">Selecione</option>
              <option value="regularizacao">Regularização &amp; Compliance</option>
              <option value="seguranca">Segurança do Trabalho</option>
              <option value="saude">Saúde Ocupacional</option>
              <option value="apoio">Apoio Operacional</option>
              <option value="nao-sei">Não sei ainda — preciso de diagnóstico</option>
            </select>
          </div>
          <div class="form-group">
            <label for="mensagem">Mensagem</label>
            <textarea id="mensagem" name="mensagem" placeholder="Conte um pouco da situação atual da sua empresa"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Enviar mensagem</button>
          <p class="form-note">Ao enviar, você abrirá seu aplicativo de e-mail padrão com a mensagem preenchida.</p>
        </form>
      </div>

    </div>
  </div>
</section>
</Layout>
