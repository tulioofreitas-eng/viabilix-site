---
interface Props {
  active: 'inicio' | 'servicos' | 'sobre' | 'contato';
}
const { active } = Astro.props;
const link = (page: Props['active']) => (active === page ? 'active' : undefined);
---
<header class="site-header">
  <div class="wrap">
    <a href="/" class="logo"><img src="/assets/img/logo-full.png" alt="Viabilix — projetos e licenciamento"></a>
    <button class="nav-toggle" id="navToggle" aria-label="Abrir menu"><span></span><span></span><span></span></button>
    <nav class="main-nav" id="mainNav">
      <ul>
        <li><a href="/" class={link('inicio')}>Início</a></li>
        <li><a href="/servicos" class={link('servicos')}>Serviços</a></li>
        <li><a href="/sobre" class={link('sobre')}>Sobre</a></li>
        <li><a href="/contato" class={link('contato')}>Contato</a></li>
      </ul>
    </nav>
    <div class="nav-right">
      <a href="/contato" class="btn btn-outline">Fale com a gente</a>
    </div>
  </div>
</header>
