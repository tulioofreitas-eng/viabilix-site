---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BotaoWhatsapp from '../components/BotaoWhatsapp.astro';

interface Props {
  title: string;
  description: string;
  active: 'inicio' | 'servicos' | 'sobre' | 'contato';
}
const { title, description, active } = Astro.props;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href="/assets/img/favicon-32.png" sizes="32x32" />
  <link rel="icon" type="image/png" href="/assets/img/favicon-192.png" sizes="192x192" />
  <link rel="apple-touch-icon" href="/assets/img/favicon-180.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body>
  <Header active={active} />
  <slot />
  <Footer />
  <BotaoWhatsapp />
  <script is:inline src="/assets/js/main.js"></script>
</body>
</html>
